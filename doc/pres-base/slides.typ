        `struct`,
        arrow[CBOR encode],
        `bytes`,
        arrow[USB Bulk Transfer],
    ),
    none,

    none, line(length: 10cm), none,

    [Агент 2\ Режим `listen`],
    grid(
        gutter: 5mm,
        arrow[USB Bulk Transfer],
        `bytes`,
        arrow[CBOR decode],
        `struct`,
    ),
    none,
)

